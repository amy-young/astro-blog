---
import { getCollection } from "astro:content";

const allPosts = await getCollection("post");

function parseDate(dateStr) {
  const [month, day, year] = dateStr.split(" ");
  return new Date(`${month} ${parseInt(day)}, ${year}`);
}

const sortedPosts = allPosts
  .map((post) => ({
    ...post,
    date: parseDate(post.data.dateFormatted),
    link: `/post/${post.slug}`,
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const featured = sortedPosts[0];
const rest = sortedPosts.slice(1, 4);

const cardGradients = [
  "from-sky-50 to-blue-100/70 dark:from-sky-900/30 dark:to-blue-900/20",
  "from-violet-50 to-purple-100/70 dark:from-violet-900/30 dark:to-purple-900/20",
  "from-emerald-50 to-teal-100/70 dark:from-emerald-900/30 dark:to-teal-900/20",
];
---

<section class="max-w-4xl mx-auto px-7 xl:px-0 pb-24">
  <!-- Divider above blog section -->
  <div class="w-full h-px border-t border-dashed border-neutral-300 dark:border-neutral-600 mb-16"></div>

  <!-- Section header -->
  <div class="flex items-baseline justify-between mb-10">
    <h2 class="text-3xl font-bold tracking-tight md:text-4xl lg:text-5xl dark:text-white">
      Useful Things & Ideas
    </h2>
    <a
      href="/posts"
      class="flex items-center gap-1.5 text-sm font-medium text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white transition-colors duration-200"
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17L17 7M17 7H7M17 7v10"/>
      </svg>
      Browse all articles
    </a>
  </div>

  <!-- Featured post -->
  {featured && (
    <a
      href={featured.link}
      class="group flex flex-col sm:flex-row w-full rounded-2xl overflow-hidden mb-8 bg-white dark:bg-neutral-900 border border-sky-100 dark:border-neutral-800 hover:border-sky-300 dark:hover:border-sky-900 shadow-sm hover:shadow-lg transition-all duration-300"
    >
      <!-- Left: content -->
      <div class="flex flex-col justify-between p-8 sm:p-10 sm:w-1/2">
        <div>
          <span class="inline-block mb-4 px-2.5 py-1 text-[10px] font-semibold tracking-widest uppercase rounded-full bg-neutral-900 text-white dark:bg-white dark:text-neutral-900">
            Featured
          </span>
          <h3 class="text-2xl md:text-3xl font-bold leading-snug tracking-tight text-neutral-900 dark:text-neutral-100 mb-4 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors duration-200">
            {featured.data.title}
          </h3>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
            {featured.data.description}
          </p>
        </div>
        <div class="flex items-center justify-between mt-8">
          <span class="text-xs text-neutral-400 dark:text-neutral-500">{featured.data.dateFormatted}</span>
          <span class="flex items-center gap-1 text-xs font-semibold text-neutral-700 dark:text-neutral-300 group-hover:gap-2 transition-all duration-200">
            Read article
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </div>
      </div>
      <!-- Right: image placeholder -->
      <div class="relative sm:w-1/2 min-h-[260px] sm:min-h-0 bg-gradient-to-br from-sky-100 via-indigo-50 to-violet-100/60 dark:from-sky-900/30 dark:via-indigo-900/20 dark:to-violet-900/20 overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center opacity-30 dark:opacity-20">
          <svg class="w-32 h-32 text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <!-- decorative lines -->
        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neutral-300 dark:via-neutral-600 to-transparent"></div>
        <div class="absolute top-8 left-8 right-8 h-px bg-neutral-200 dark:bg-neutral-700 opacity-60"></div>
        <div class="absolute top-16 left-8 right-16 h-px bg-neutral-200 dark:bg-neutral-700 opacity-40"></div>
        <div class="absolute top-24 left-8 right-12 h-px bg-neutral-200 dark:bg-neutral-700 opacity-30"></div>
      </div>
    </a>
  )}

  <!-- Smaller post cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
    {rest.map((post, i) => (
      <a
        href={post.link}
        class="group flex flex-col rounded-2xl overflow-hidden border border-neutral-100 dark:border-neutral-800 hover:border-neutral-300 dark:hover:border-neutral-600 bg-white dark:bg-neutral-900 shadow-sm hover:shadow-md transition-all duration-300"
      >
        <!-- Image placeholder -->
        <div class={`h-40 bg-gradient-to-br ${cardGradients[i % cardGradients.length]} flex items-center justify-center`}>
          <svg class="w-10 h-10 text-neutral-300 dark:text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <!-- Content -->
        <div class="flex flex-col justify-between flex-1 p-5">
          <h3 class="text-sm font-bold leading-snug text-neutral-900 dark:text-neutral-100 mb-4 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors duration-200">
            {post.data.title}
          </h3>
          <div class="flex items-center justify-between">
            <span class="text-xs text-neutral-400 dark:text-neutral-500">{post.data.dateFormatted}</span>
            <svg class="w-3.5 h-3.5 text-neutral-300 dark:text-neutral-600 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 group-hover:translate-x-0.5 transition-all duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
