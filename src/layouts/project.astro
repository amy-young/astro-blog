---
import Layout from "./main.astro";
const { frontmatter } = Astro.props;

const statusLabel = {
  active: "Active",
  building: "Building",
  shipped: "Shipped",
};

const statusColor = {
  active: "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300",
  building: "bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300",
  shipped: "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300",
};

const categoryColor = {
  work: "bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-300",
  personal: "bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400",
};
---

<Layout title={frontmatter.title}>
  <main class="relative z-30 max-w-4xl pb-1 mx-auto mt-10 bg-white dark:bg-neutral-950 md:rounded-t-md text-neutral-900">

    <!-- Side border decorations -->
    <div class="relative flex flex-col px-5 pt-6 border-t border-b-0 md:border-r md:border-l md:pt-16 lg:px-0 justify-stretch md:rounded-t-2xl border-neutral-200 dark:border-neutral-800">
      <div class="absolute top-0 left-0 hidden w-px h-full mt-1 -translate-x-px md:block bg-gradient-to-b from-transparent to-white dark:to-neutral-950"></div>
      <div class="absolute top-0 right-0 hidden w-px h-full mt-1 translate-x-px md:block bg-gradient-to-b from-transparent to-white dark:to-neutral-950"></div>

      <!-- Back link -->
      <div class="w-full max-w-2xl mx-auto mb-8">
        <a href="/projects" class="inline-flex items-center gap-1.5 text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors duration-200">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          All projects
        </a>
      </div>

      <!-- Badges -->
      <div class="w-full max-w-2xl mx-auto flex flex-wrap items-center gap-2 mb-5">
        <span class={`px-2.5 py-1 text-[10px] font-semibold tracking-widest uppercase rounded-full ${statusColor[frontmatter.status]}`}>
          {statusLabel[frontmatter.status]}
        </span>
        <span class={`px-2.5 py-1 text-[10px] font-semibold tracking-widest uppercase rounded-full ${categoryColor[frontmatter.category]}`}>
          {frontmatter.category}
        </span>
      </div>

      <!-- Title -->
      <h1 class="w-full max-w-2xl mx-auto text-3xl font-bold leading-tight tracking-tighter text-left md:text-4xl dark:text-neutral-100 lg:text-5xl md:leading-none mb-4">
        {frontmatter.title}
      </h1>

      <!-- Description -->
      <p class="w-full max-w-2xl mx-auto text-lg text-neutral-500 dark:text-neutral-400 leading-relaxed mb-8">
        {frontmatter.description}
      </p>

      <!-- Meta row -->
      <div class="w-full max-w-2xl mx-auto flex flex-wrap items-center gap-6 pb-8 border-b border-dashed border-neutral-200 dark:border-neutral-800">
        {frontmatter.startDate && (
          <div class="flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            Started {frontmatter.startDate}
          </div>
        )}
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {frontmatter.tags.map((tag) => (
              <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
                {tag}
              </span>
            ))}
          </div>
        )}
        {(frontmatter.liveUrl || frontmatter.githubUrl) && (
          <div class="flex gap-3 ml-auto">
            {frontmatter.liveUrl && (
              <a href={frontmatter.liveUrl} target="_blank" class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-full bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-200 transition-colors duration-200">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                </svg>
                View live
              </a>
            )}
            {frontmatter.githubUrl && (
              <a href={frontmatter.githubUrl} target="_blank" class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-full border border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors duration-200">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                </svg>
                GitHub
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- Content -->
    <article class="w-full max-w-2xl mx-auto mb-20 prose-sm prose px-7 lg:px-0 lg:prose-lg dark:prose-invert pt-10">
      <slot />
    </article>
  </main>
</Layout>
