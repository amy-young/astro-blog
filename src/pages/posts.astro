---
import { getCollection } from "astro:content";
import Layout from "../layouts/main.astro";

const allPosts = await getCollection("post");

function parseDate(dateStr: string) {
  const [month, day, year] = dateStr.split(" ");
  return new Date(`${month} ${parseInt(day)}, ${year}`);
}

const sortedPosts = allPosts
  .map((post) => ({
    ...post,
    date: parseDate(post.data.dateFormatted),
    link: `/post/${post.slug}`,
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const featured = sortedPosts[0];
const rest = sortedPosts.slice(1);

const allTags = ["All", ...Array.from(new Set(sortedPosts.flatMap(p => p.data.tags ?? [])))];

const tagColors: Record<string, string> = {
  "AI":       "bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-300",
  "Product":  "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300",
  "Science":  "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300",
  "Data":     "bg-cyan-100 text-cyan-700 dark:bg-cyan-900/40 dark:text-cyan-300",
  "Sports":   "bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300",
  "Travel":   "bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-300",
};

const defaultTagColor = "bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400";

const cardGradients = [
  "from-sky-50 to-blue-100/70 dark:from-sky-900/30 dark:to-blue-900/20",
  "from-violet-50 to-purple-100/70 dark:from-violet-900/30 dark:to-purple-900/20",
  "from-emerald-50 to-teal-100/70 dark:from-emerald-900/30 dark:to-teal-900/20",
  "from-rose-50 to-pink-100/70 dark:from-rose-900/30 dark:to-pink-900/20",
  "from-amber-50 to-orange-100/70 dark:from-amber-900/30 dark:to-orange-900/20",
  "from-cyan-50 to-sky-100/70 dark:from-cyan-900/30 dark:to-sky-900/20",
];
---

<Layout title="Useful Things">
  <div class="relative z-20 w-full max-w-4xl mx-auto mt-16 px-7 md:mt-24 lg:mt-28 xl:px-0">

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl dark:text-white mb-4">
        Useful Things & Ideas
      </h1>
      <p class="text-base text-neutral-500 dark:text-neutral-400 max-w-xl leading-relaxed">
        Ideas from the intersection of science, AI, product, sports, and life
      </p>
    </div>

    <!-- Why I Write call-out -->
    <a
      href="/why-i-write"
      class="group flex items-center justify-between w-full mb-10 px-6 py-4 rounded-2xl border border-violet-100 dark:border-violet-900/50 bg-violet-50 dark:bg-violet-950/30 hover:border-violet-300 dark:hover:border-violet-700 transition-all duration-200"
    >
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase text-violet-500 dark:text-violet-400 mb-1">A note</p>
        <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300">I write because I want to connect. Find others wrestling with the same questions, and learn together.</p>
      </div>
      <span class="flex items-center gap-1 text-xs font-semibold text-violet-500 dark:text-violet-400 group-hover:gap-2 transition-all duration-200 ml-6 shrink-0">
        Why I write
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </a>

    <!-- Featured post -->
    {featured && (
      <a
        href={featured.link}
        class="group flex flex-col sm:flex-row w-full rounded-2xl overflow-hidden mb-10 bg-white dark:bg-neutral-900 border border-sky-100 dark:border-neutral-800 hover:border-sky-300 dark:hover:border-sky-900 shadow-sm hover:shadow-lg transition-all duration-300"
      >
        <!-- Left: content -->
        <div class="flex flex-col justify-between p-8 sm:p-10 sm:w-1/2">
          <div>
            <div class="flex items-center gap-2 mb-4 flex-wrap">
              <span class="inline-block px-2.5 py-1 text-[10px] font-semibold tracking-widest uppercase rounded-full bg-neutral-900 text-white dark:bg-white dark:text-neutral-900">
                Latest
              </span>
              {featured.data.tags && featured.data.tags.slice(0,2).map(tag => (
                <span class={`inline-block px-2.5 py-1 text-[10px] font-semibold tracking-widest uppercase rounded-full ${tagColors[tag] ?? defaultTagColor}`}>
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-2xl md:text-3xl font-bold leading-snug tracking-tight text-neutral-900 dark:text-neutral-100 mb-4 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors duration-200">
              {featured.data.title}
            </h2>
            <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
              {featured.data.description}
            </p>
          </div>
          <div class="flex items-center justify-between mt-8">
            <span class="text-xs text-neutral-400 dark:text-neutral-500">{featured.data.dateFormatted}</span>
            <span class="flex items-center gap-1 text-xs font-semibold text-neutral-700 dark:text-neutral-300 group-hover:gap-2 transition-all duration-200">
              Read article
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </div>
        <!-- Right: decorative panel -->
        <div class="relative sm:w-1/2 min-h-[260px] sm:min-h-0 bg-gradient-to-br from-sky-100 via-indigo-50 to-violet-100/60 dark:from-sky-900/30 dark:via-indigo-900/20 dark:to-violet-900/20 overflow-hidden">
          <div class="absolute inset-0 flex items-center justify-center opacity-30 dark:opacity-20">
            <svg class="w-32 h-32 text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neutral-300 dark:via-neutral-600 to-transparent"></div>
          <div class="absolute top-8 left-8 right-8 h-px bg-neutral-200 dark:bg-neutral-700 opacity-60"></div>
          <div class="absolute top-16 left-8 right-16 h-px bg-neutral-200 dark:bg-neutral-700 opacity-40"></div>
          <div class="absolute top-24 left-8 right-12 h-px bg-neutral-200 dark:bg-neutral-700 opacity-30"></div>
        </div>
      </a>
    )}

    <!-- Category filter -->
    {allTags.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-8" id="tag-filters">
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class={`tag-filter px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 border ${
              tag === "All"
                ? "bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 border-neutral-900 dark:border-white"
                : "bg-white dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border-neutral-200 dark:border-neutral-700 hover:border-neutral-400 dark:hover:border-neutral-500"
            }`}
          >
            {tag}
          </button>
        ))}
      </div>
    )}

    <!-- All other posts grid -->
    {rest.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 pb-24" id="posts-grid">
        {rest.map((post, i) => (
          <a
            href={post.link}
            data-tags={JSON.stringify(post.data.tags ?? [])}
            class="post-card group flex flex-col rounded-2xl overflow-hidden border border-neutral-100 dark:border-neutral-800 hover:border-neutral-300 dark:hover:border-neutral-600 bg-white dark:bg-neutral-900 shadow-sm hover:shadow-md transition-all duration-300"
          >
            <!-- Gradient thumbnail -->
            <div class={`h-36 bg-gradient-to-br ${cardGradients[i % cardGradients.length]} flex items-center justify-center relative overflow-hidden`}>
              {post.data.tags && post.data.tags[0] && (
                <span class={`absolute top-3 left-3 px-2.5 py-1 text-[10px] font-semibold tracking-widest uppercase rounded-full ${tagColors[post.data.tags[0]] ?? defaultTagColor}`}>
                  {post.data.tags[0]}
                </span>
              )}
              <svg class="w-10 h-10 text-neutral-300 dark:text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <!-- Content -->
            <div class="flex flex-col justify-between flex-1 p-5">
              <div>
                <h3 class="text-sm font-bold leading-snug text-neutral-900 dark:text-neutral-100 mb-2 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors duration-200">
                  {post.data.title}
                </h3>
                <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
              </div>
              <div class="flex items-center justify-between mt-4 pt-4 border-t border-neutral-100 dark:border-neutral-800">
                <span class="text-xs text-neutral-400 dark:text-neutral-500">{post.data.dateFormatted}</span>
                <svg class="w-3.5 h-3.5 text-neutral-300 dark:text-neutral-600 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 group-hover:translate-x-0.5 transition-all duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

  </div>
</Layout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>(".tag-filter");
  const cards = document.querySelectorAll<HTMLElement>(".post-card");

  filters.forEach(btn => {
    btn.addEventListener("click", () => {
      const selected = btn.dataset.tag ?? "All";

      // Update active button styles
      filters.forEach(f => {
        const isActive = f.dataset.tag === selected;
        f.className = isActive
          ? "tag-filter px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 border bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 border-neutral-900 dark:border-white"
          : "tag-filter px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 border bg-white dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border-neutral-200 dark:border-neutral-700 hover:border-neutral-400 dark:hover:border-neutral-500";
      });

      // Show/hide cards
      cards.forEach(card => {
        if (selected === "All") {
          card.style.display = "";
        } else {
          const tags: string[] = JSON.parse(card.dataset.tags ?? "[]");
          card.style.display = tags.includes(selected) ? "" : "none";
        }
      });
    });
  });
</script>
