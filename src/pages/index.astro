---
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="Amy">
  <div class="relative z-20 w-full max-w-4xl mx-auto mt-16 px-7 md:mt-24 lg:mt-28 xl:px-0">
    <!-- Decorative glow behind the card -->
    <div class="absolute -inset-8 rounded-[3rem] bg-gradient-to-br from-stone-200/60 via-amber-100/30 to-transparent dark:from-neutral-800/60 dark:via-neutral-700/20 dark:to-transparent blur-3xl pointer-events-none -z-10"></div>

    <!-- Hero card -->
    <div class="flex flex-col md:flex-row overflow-hidden rounded-3xl border-[10px] border-white dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-md min-h-[420px]">

      <!-- Left: text content -->
      <div class="flex flex-col justify-center p-10 md:p-12 md:w-1/2 bg-gradient-to-br from-stone-100 via-amber-50/60 to-neutral-50 dark:from-neutral-800 dark:via-neutral-850 dark:to-neutral-900">
        <h1 class="mb-4 text-4xl font-bold leading-tight lg:text-5xl dark:text-white">
          Hello, I'm Amy.
        </h1>
        <p class="mb-5 text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
          I'm a product manager and aspiring AI builder living in Seattle.
        </p>
        <p class="mb-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200">
          I enjoy working on a variety of projects, including:
        </p>
        <ul class="py-2 space-y-1 text-sm list-disc list-inside text-neutral-500 dark:text-neutral-400">
          <li>AI Agents & Automation</li>
          <li>Communications & Information Management</li>
          <li>Product Design & Development</li>
          <li>Data Science & Analytics</li>
        </ul>
        <a
          href="https://www.linkedin.com/in/amyyoung-data-ai/"
          class="inline-flex items-center gap-2 w-auto self-start px-4 py-2 mt-6 text-xs font-semibold duration-300 ease-out border rounded-full bg-neutral-900 dark:bg-white dark:text-neutral-900 text-neutral-100 hover:border-neutral-700 border-neutral-900 dark:hover:border-neutral-300 hover:bg-white dark:hover:bg-black dark:hover:text-white hover:text-neutral-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Follow me on LinkedIn
        </a>
      </div>

      <!-- Right: photo full-bleed, clipped by card's rounded corners -->
      <div class="md:w-1/2 min-h-[360px] md:min-h-0">
        <img
          src="/assets/images/amy-young-dt.jpeg"
          loading="eager"
          decoding="auto"
          class="w-full h-full object-cover object-top"
        />
      </div>

    </div>
  </div>

  <!-- About Me section -->
  <div class="w-full max-w-4xl mx-auto px-7 xl:px-0">
    <!-- Divider above -->
    <div class="w-full h-px border-t border-dashed border-neutral-300 dark:border-neutral-600 mt-16 mb-16"></div>

    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

      <!-- Left: stacked polaroid photos -->
      <div class="relative flex-shrink-0 w-80 h-[360px] mr-8 md:mr-12">
        <!-- Back photo -->
        <div class="absolute top-0 left-0 w-56 h-56 bg-white dark:bg-neutral-800 rounded-2xl shadow-lg p-2.5 -rotate-3">
          <img
            src="/assets/images/amy-young_sailing-2.jpeg"
            alt=""
            class="w-full h-full object-cover rounded-xl"
          />
        </div>
        <!-- Front photo — overlaps only the bottom-right corner of the back photo -->
        <div class="absolute top-[170px] left-[155px] w-52 h-52 bg-white dark:bg-neutral-800 rounded-2xl shadow-xl p-2.5 rotate-3">
          <img
            src="/assets/images/amy-young-street-jj.jpeg"
            alt="Amy Young"
            class="w-full h-full object-cover object-top rounded-xl"
          />
        </div>
      </div>

      <!-- Right: text content -->
      <div class="flex-1">
        <h2 class="text-4xl font-bold tracking-tight md:text-5xl dark:text-white mb-6">
          About me
        </h2>
        <p class="text-base text-neutral-700 dark:text-neutral-300 leading-relaxed mb-4">
          I'm a product manager and AI builder living in Seattle, WA. I have a passion for building things that make people's lives easier and more meaningful.
        </p>
        <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed mb-6">
          My background spans data science, communications, and product design — a combination that lets me approach problems from multiple perspectives and build end-to-end solutions.
        </p>
        <ul class="space-y-2.5">
          {[
            "AI Agents & Automation",
            "Product Design & Development",
            "Data Science & Analytics",
            "Communications & Information Management",
          ].map((skill) => (
            <li class="flex items-center gap-2.5 text-sm text-neutral-700 dark:text-neutral-300">
              <svg class="w-4 h-4 flex-shrink-0 text-neutral-900 dark:text-neutral-100" viewBox="0 0 24 24" fill="currentColor">
                <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" />
              </svg>
              {skill}
            </li>
          ))}
        </ul>
      </div>
    </div>

  </div>

  <Separator text="My Workbench" />
  <Projects />
  <Writings />
</Layout>
